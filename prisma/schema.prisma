generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url  	    = env("DATABASE_URL")
}

model Users {
  id            Int            @id @default(autoincrement())
  phoneNumber   String         @unique() @db.VarChar(30)
  name          String?        @db.VarChar(200)
  role          Role?
  identifier    String?        @db.VarChar(255)
  createdAt     DateTime?      @default(now()) @map("created_at") @db.Timestamp(0)
  conversations Conversation[]

  @@map("users")
}

model Admins {
  id          Int             @id @default(autoincrement())
  username    String          @unique
  fullName    String          @map("full_name")
  password    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Conversation {
  id                  Int       @id @default(autoincrement())
  userId              Int       @map("user_id")
  category            Category?
  last_bot_message_id Int?      @map("last_bot_message_id")
  step                Step
  createdAt           DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  user                Users     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "conversations_ibfk_1")
  messages            Message[]

  @@index([userId], map: "user_id")
  @@map("conversations")
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int          @map("conversation_id")
  sender         Sender
  message_text   String       @map("message_text") @db.Text
  need_human     Boolean?     @default(false) @map("need_human")
  feedback       Feedback?
  createdAt      DateTime?    @default(now()) @map("created_at") @db.Timestamp(0)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "messages_ibfk_1")
  unresolved     Unresolved[]

  @@index([conversationId], map: "conversation_id")
  @@map("messages")
}

model Unresolved {
  id         Int       @id @default(autoincrement())
  messageId  Int       @map("message_id")
  status     Status?   @default(open)
  assignedTo String?   @map("assigned_to") @db.VarChar(100)
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime  @updatedAt @map("updated_at")
  message    Message   @relation(fields: [messageId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "unresolved_ibfk_1")

  @@index([messageId], map: "message_id")
  @@map("unresolved")
}

model Schedule {
  id                Int             @id @default(autoincrement())
  eventTitle        String          @map("event_title")
  eventDescription  String          @db.Text @map("event_description")
  eventTime         DateTime        @map("event_time")
  reminderTime      DateTime        @map("reminder_time")
  status            ScheduleStatus  @default(pending)
  createdBy         String          @map("created_by")
  createdAt         DateTime        @default(now()) @map("created_at")

  // Relasi: Satu Jadwal bisa punya banyak Penerima
  recipients       ScheduleRecipient[]

  @@map("schedules")
}

model ScheduleRecipient {
  id                Int             @id @default(autoincrement())
  scheduleId        Int             @map("schedule_id")
  schedule          Schedule        @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  contactId         Int?             @map("contact_id")
  contact           Contacts?        @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("schedule_recipients")
}

model Contacts {
  id                Int             @id @default(autoincrement())
  name              String
  title             String
  phoneNumber       String          @unique @map("phone_number")
  notes             String?         @map("notes") @db.Text

  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  schedules         ScheduleRecipient[]

  @@map("contacts")
}

model PartnershipDocument {
  id                  Int             @id @default(autoincrement())
  yearIssued          Int             @map("year_issued")
  docType             DocType?        @map("doc_type")
  partnerName         String          @map("partner_name")
  scope               Scope?
  
  picExternal         String?         @map("pic_external")
  picExternalPhone    String?         @map("pic_external_phone")
  picInternal         String?         @map("pic_internal")
  

  docNumberInternal   String?         @unique @map("doc_number_internal")
  docNumberExternal   String?         @unique @map("doc_number_external")
  

  partnershipType     PartnershipType? @map("partnership_type")
  activityType        ActivityType?    @map("activity_type")
  
  dateCreated         DateTime?       @map("date_created")
  signingType         String?         @map("signing_type")
  dateSigned          DateTime?       @map("date_signed")
  validUntil          DateTime?       @map("valid_until")
  duration            String?         @map("duration") 
  
  // --- APPROVAL WORKFLOW (Baju Surat) ---
  approvalWadek2      ApprovalStatus? @map("approval_wadek2")
  approvalWadek1      ApprovalStatus? @map("approval_wadek1")
  approvalKabagKST    ApprovalStatus? @map("approval_kabag_kst")
  approvalDirSPIO     ApprovalStatus? @map("approval_dir_spio")
  approvalKaurLegal   ApprovalStatus? @map("approval_kaur_legal")
  approvalKabagSekpim ApprovalStatus? @map("approval_kabag_sekpim")
  approvalDirSPS      ApprovalStatus? @map("approval_dir_sps")
  approvalDekan       ApprovalStatus? @map("approval_dekan")
  approvalWarek1      ApprovalStatus? @map("approval_warek1")
  approvalRektor      ApprovalStatus? @map("approval_rektor")

  // --- Arsip & Lainnya ---
  docLink             String?         @map("doc_link")
  notes               String?         @db.Text
  
  hasHardcopy         Boolean         @default(false) @map("has_hardcopy")
  hasSoftcopy         Boolean         @default(false) @map("has_softcopy")

  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  @@map("partnership_documents")
}

enum Role {
  mahasiswa
  dosen
}

enum Category {
  Sidang
  Keuangan
  Wisuda
  Sekretariat
  Wadek1
  Wadek2
  ProdiS1
  ProdiS2
}

enum Step {
  select_role
  ask_lecturer_name
  lecturer_select_unit
  ask_student_nim
  ask_student_name
  menu
  chat
  awaiting_feedback
}

enum Sender {
  user
  bot
  admin
}

enum Feedback {
  ONE   @map("1")
  TWO   @map("2")
  THREE @map("3")
}

enum Status {
  open
  in_progress
  resolved
}

enum ScheduleStatus {
  draft
  pending
  sent
  cancelled
}

enum DocType {
  MoA
  MoU
  IA
}

enum Scope {
  national
  international
}

enum PartnershipType {
  Akademik
  Penelitian
  Abdimas
}

enum ActivityType {
  // --- Sub Akademik ---
  JointDegree
  DoubleDegree
  JointClass
  StudentExchange
  VisitingProfessor

  // --- Sub Penelitian ---
  JointResearch
  JointPublication

  // --- Sub Abdimas ---
  JointCommunityService
  SocialProject
  
  // --- Umum ---
  General
}

enum ApprovalStatus {
  Approved
  Returned
  Submitted
  Pending
  Skipped // Opsional: jika tidak perlu lewat ponggawa tsb
}